# AI SQL Agent Configuration
# Copy this file to .env and fill in your API keys

# Default LLM provider: openai | glm | mimo | claude | deepseek | qwen
AI_DEFAULT_PROVIDER=openai

# --- Provider API Keys ---
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_MODEL=gpt-4o

AI_GLM_API_KEY=
AI_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_GLM_MODEL=glm-4-plus

AI_MIMO_API_KEY=
AI_MIMO_BASE_URL=https://api.xiaomimimo.com/v1
AI_MIMO_MODEL=mimo-v2.5

AI_CLAUDE_API_KEY=
AI_CLAUDE_MODEL=claude-sonnet-4-20250514

AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_DEEPSEEK_MODEL=deepseek-chat

AI_QWEN_API_KEY=
AI_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_QWEN_MODEL=qwen-plus

# --- Database Connection (optional, for SQL execution & schema inspection) ---
# DB_TYPE=dm|mysql|postgres
# DB_HOST=localhost
# DB_PORT=5236
# DB_NAME=your_database
# DB_USER=your_user
# DB_PASSWORD=your_password
